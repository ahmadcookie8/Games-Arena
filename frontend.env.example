# Frontend Environment Variables
# Copy this file to frontend/.env and fill in your actual values

# ============================================
# API Configuration
# ============================================
# Backend API URL (Node.js + Express server)
# Development (local):
VITE_API_URL=http://localhost:3000

# Production:
# VITE_API_URL=https://api.penguincookie.ca

# ============================================
# Socket.io Configuration
# ============================================
# WebSocket server URL (same as API for this project)
# Development (local):
VITE_SOCKET_URL=http://localhost:3000

# Production:
# VITE_SOCKET_URL=https://api.penguincookie.ca

# ============================================
# Environment
# ============================================
# development | production | staging
VITE_ENV=development

# ============================================
# Optional: Analytics (Future)
# ============================================
# VITE_GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X
# VITE_SENTRY_DSN=https://...

# ============================================
# Optional: Feature Flags
# ============================================
# Enable debug mode (shows extra logs)
VITE_DEBUG=true

# Enable experimental features
VITE_EXPERIMENTAL=false
