# Backend Environment Variables
# Copy this file to backend/.env and fill in your actual values

# ============================================
# Server Configuration
# ============================================
NODE_ENV=development
PORT=3000

# ============================================
# Database (MongoDB Atlas)
# ============================================
# Get this from MongoDB Atlas:
# 1. Go to https://cloud.mongodb.com
# 2. Create cluster
# 3. Click "Connect" → "Drivers"
# 4. Copy connection string
# 5. Replace <password> with your password
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/multiplayer-games?retryWrites=true&w=majority

# ============================================
# Redis Cache
# ============================================
# For local development with Docker:
REDIS_URL=redis://localhost:6379

# For production (if using managed Redis):
# REDIS_URL=redis://:password@hostname:6379

# ============================================
# Authentication
# ============================================
# Generate a strong random string for JWT secret
# Run: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# ============================================
# CORS Configuration
# ============================================
# Which frontend URL can access this backend
# Development:
CORS_ORIGIN=http://localhost:5173

# Production:
# CORS_ORIGIN=https://penguincookie.ca

# ============================================
# Logging
# ============================================
LOG_LEVEL=debug

# Options: error, warn, info, debug, trace
# Use 'debug' for development, 'info' for production

# ============================================
# Optional: Game Configuration
# ============================================
# Maximum concurrent games allowed
MAX_CONCURRENT_GAMES=1000

# Game timeout (minutes) - auto-resign if no move
GAME_TIMEOUT_MINUTES=5

# ============================================
# Optional: Rate Limiting
# ============================================
# Requests per minute for auth endpoints
RATE_LIMIT_AUTH=5

# ============================================
# Optional: Email Configuration (Future)
# ============================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
