# Backend Environment Variables
# Copy this file to backend/.env and fill in your actual values

# ============================================
# Server Configuration
# ============================================
NODE_ENV=development
PORT=3000

# ============================================
# Database (MongoDB Atlas)
# ============================================
# Get this from MongoDB Atlas:
# 1. Go to https://cloud.mongodb.com
# 2. Create cluster
# 3. Click "Connect" → "Drivers"
# 4. Copy connection string
# 5. Replace <password> with your password
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/multiplayer-games?retryWrites=true&w=majority

# ============================================
# Redis Cache
# ============================================
# For local development with Docker:
REDIS_URL=redis://localhost:6379

# For production (if using managed Redis):
# REDIS_URL=redis://:password@hostname:6379

# ============================================
# Authentication
# ============================================
# Generate a strong random string for JWT secret
# Run: openssl rand -base64 32
JWT_SECRET=

# ============================================
# CORS Configuration
# ============================================
# Which frontend URL can access this backend
# Development:
CORS_ORIGIN=http://localhost:5173

# Production:
# CORS_ORIGIN=https://games.penguincookie.ca

# ============================================
# Logging
# ============================================
LOG_LEVEL=debug

# Options: error, warn, info, debug, trace
# Use 'debug' for development, 'info' for production

# Existing 6-character room codes stop working after this finite migration window.
# New 8-character codes always expire 24 hours after room creation.
LEGACY_GAME_CODE_CUTOFF=2026-10-15T00:00:00.000Z

# ============================================
# Optional: Email Configuration (Future)
# ============================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
